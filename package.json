{
  "name": "daiblos-spine-observatory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "assets:sync": "node scripts/sync-assets.mjs",
    "generate:manifest": "node scripts/generate-manifest.mjs",
    "generate:manifest:remote": "node scripts/generate-manifest.mjs --remote"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.3.0",
    "@pixi-spine/all-3.8": "4.0.6",
    "pixi.js": "7.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "gh-pages": "^6.3.0",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  }
}
